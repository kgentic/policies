{
  "name": "kgentic-policies",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "description": "Policy registry and CLI for AI coding agents",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "changeset": "changeset",
    "sync-versions": "node scripts/sync-plugin-versions.js",
    "release": "changeset version && node scripts/sync-plugin-versions.js",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.20",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
