#!/usr/bin/env bash
set -eu

REMOTE="$1"
NEEDS_REPUSH=0

# ── Recursion guards ──────────────────────────────────────────────────────────
# Changeset re-push sets KGENTIC_RELEASING; gah sets GAH_ACTIVE.
if [ "${KGENTIC_RELEASING:-}" = "1" ]; then exit 0; fi
if [ "${GAH_ACTIVE:-}" = "yes" ]; then exit 0; fi

# ── 1. Changeset auto-release ────────────────────────────────────────────────
# If pending changeset files exist, run `pnpm release` to consume them,
# stage the resulting version bumps + CHANGELOGs, and commit. The push is
# deferred — either gah handles it (section 2) or we do it ourselves (section 3).
PENDING=$(find .changeset -name '*.md' ! -name 'README.md' 2>/dev/null | head -1)

if [ -n "$PENDING" ]; then
  echo ""
  echo "📦 Pending changesets detected — running release..."
  echo ""

  if ! pnpm release; then
    echo ""
    echo "❌ pnpm release failed. Push aborted."
    exit 1
  fi

  RELEASE_CHANGES=$(git status --porcelain 2>/dev/null | head -1)

  if [ -n "$RELEASE_CHANGES" ]; then
    # Stage all release artifacts (suppress errors for files that don't exist)
    git add \
      .changeset/ \
      packages/*/package.json \
      packages/*/CHANGELOG.md \
      2>/dev/null

    STAGED=$(git diff --cached --name-only 2>/dev/null | head -1)

    if [ -n "$STAGED" ]; then
      git commit --no-verify -m "chore(release): bump plugin versions"
      NEEDS_REPUSH=1
    fi
  fi
fi

# ── 2. Git-after-hours (gah) ─────────────────────────────────────────────────
# Opt-in: requires .gahrc to exist
GAH_ACTIVE_REPO=0
if [ -f ".gahrc" ] || [ -f ".gahrc.json" ] || [ -f ".gahrc.yaml" ] || [ -f ".gahrc.yml" ]; then
  GAH_ACTIVE_REPO=1

  # Block during work hours if configured
  BLOCK_CHECK=$(gah check-hours 2>&1) || true
  if echo "$BLOCK_CHECK" | grep -q "BLOCKED"; then
    echo "$BLOCK_CHECK" | grep -v "BLOCKED"
    exit 1
  fi

  # Check for unpushed work-hour commits (includes any release commit from above)
  OUTPUT=$(gah --unpushed --dry-run 2>&1) || true

  if ! echo "$OUTPUT" | grep -q "commits to modify: 0"; then
    BRANCH=$(git branch --show-current)
    echo "gah: work-hour commits detected — rewriting before push"
    gah push --branch "$BRANCH"

    echo ""
    echo "✓ gah: push complete (timestamps shifted to outside work hours)"
    # gah already pushed everything (including any release commit) — abort original
    exit 1
  fi
fi

# ── 3. Re-push if release created a new commit but gah didn't push ───────────
# The original push was computed before the hook ran, so it doesn't know about
# the release commit. We need to push explicitly.
if [ "$NEEDS_REPUSH" = "1" ]; then
  echo ""
  echo "📤 Pushing with release commit included..."
  KGENTIC_RELEASING=1 git push "$REMOTE" HEAD 2>&1
  echo "✅ Release committed and pushed."
fi

exit 0
